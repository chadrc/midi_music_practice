[Desktop Entry]
<% if (productName) { %>Name=<%= productName %>
<% } %><% if (description) { %>Comment=<%= description %>
<% } %><% if (genericName) { %>GenericName=<%= genericName %>
<% } %><% if (name) { %>Exec=<%= name %> %U<% if (typeof execArguments !== 'undefined' && execArguments && execArguments.length) { %> <%= execArguments.join(' ') %><% } %>
Icon=<%= name %>
StartupWMClass=<% if (typeof startupWMClass !== 'undefined' && startupWMClass) { %><%= startupWMClass %><% } else { %><%= name %><% } %>
<% } %>Type=Application
StartupNotify=true
<% if (categories && categories.length) { %>Categories=<%= categories.join(';') %>;
<% } %><% if (mimeType && mimeType.length) { %>MimeType=<%= mimeType.join(';') %>;
<% } %>
